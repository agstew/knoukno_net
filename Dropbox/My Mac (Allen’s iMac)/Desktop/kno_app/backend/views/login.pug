extends layout

block content
  .auth-card
    h2 Login
    if error
      p.form-error #{error}
    if message
      p.form-notice #{message}
    form.auth-form(method='post' action='/auth/login')
      .field
        label(for='email') Email
        input#email(type='email' name='email' placeholder='you@example.com' required)
      .field
        label(for='password') Password
        .pw-row
          input#password(type='password' name='password' placeholder='Your password' required)
          button.pw-toggle(type='button' aria-label='Show password') Show
      .actions
        button.button-primary(type='submit') Sign in
      p.small
        a(href='/auth/forgot') Forgot password?
        |  •
        a(href='/auth/register') Create an account
