extends layout

block content
  .container
    h2= title.title
    .actions
      form(method='post' action=`/titles/${title._id}/save` style='display:inline')
        button.button-secondary(type='submit') Save
      a.button-secondary(href=`/titles/${title._id}/print` style='margin-left:8px') Print
      if user && user.tier === 'members' || user && user.tier === 'pro'
        a.button-secondary(href=`/titles/${title._id}/grade` style='margin-left:8px') Grade
        a.button-secondary(href=`/titles/${title._id}/rate` style='margin-left:8px') Rate
        a.button-secondary(href=`/titles/${title._id}/average` style='margin-left:8px') Average

    if submissions && submissions.length
      h3 Submissions
      each s in submissions
        .submission.card
          if s.user
            p.meta #{s.user.name} — #{s.createdAt.toLocaleString()}
          else
            p.meta Guest — #{s.createdAt.toLocaleString()}
          if s.type === 'grade'
            p Grade: #{s.grade} (#{s.gradeValue})
          if s.type === 'rate'
            p Rated: #{s.rating}
          if s.type === 'save'
            p Saved
    else
      p No submissions yet.

    a(href='/titles') Back
extends layout

block content
  .container
    h2= title.title

    // Buttons depending on tier
    .actions
      if currentUser && currentUser.tier
        form(method='post' action=`/titles/${title._id}/save` style='display:inline')
          button(type='submit') Save
        button(onclick='window.print()' type='button') Print
        if currentUser.tier === 'members' || currentUser.tier === 'pro'
          a(href=`/titles/${title._id}/grade`) Grade
          a(href=`/titles/${title._id}/rate`) Rate
          a(href=`/titles/${title._id}/average`) Average
      else
        p Please sign in to see actions.

    if avgRating
      p.small Average rating: #{avgRating.toFixed(2)}

    if submissions && submissions.length
      h3 Recent activity
      each s in submissions
        .submission.card
          p.meta #{s.user ? s.user.email : 'guest'} — #{s.type} — #{s.createdAt.toLocaleString()}
          if s.type === 'grade'
            p Grade: #{s.grade} (#{s.gradeValue})
          if s.type === 'rate'
            p Rating: #{s.rating}
    else
      p No activity yet.
