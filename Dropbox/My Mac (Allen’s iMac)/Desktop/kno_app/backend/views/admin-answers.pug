extends layout

block content
  .admin-layout
    .admin-sidebar
      .card
        h3 Question Answers
        a.button-secondary(href='/admin') Back to Admin
        if total
          p.meta Total answers: #{total}
        if avgRating
          p Average rating: #{avgRating.toFixed(2)} / 50
        .card
          h4 Bulk actions
          form(method='post' action='/admin/question-average-save')
            input(type='hidden' name='questionId' value=questionId)
            button.button-secondary(type='submit') Save Average for Question
    .admin-main
      h2 Answers for question
      if submissions && submissions.length
        each s in submissions
          .submission.card.admin-list-item
            .submission-row
              .meta #{s.name || 'guest'} — #{s.createdAt.toLocaleString()}
            p.answer-text #{s.answerText}
            .actions
              form(method='post' action='/admin/save' style='display:inline')
                input(type='hidden' name='id' value=s._id)
                button.button-primary(type='submit') Save
              form(method='post' action='/admin/delete' style='display:inline;margin-left:8px')
                input(type='hidden' name='id' value=s._id)
                button.button-danger(type='submit') Delete
              a(href=`/admin/grade/${s._id}` style='margin-left:8px') Grade
              a(href=`/admin/rate/${s._id}` style='margin-left:8px') Rate
              a(href=`/admin/print/${s._id}` style='margin-left:8px') Print
        .pager
          if page>1
            a(href=`/admin/question-answers/${questionId}?page=${page-1}&limit=${limit}`) Prev
          if (page*limit) < total
            a(href=`/admin/question-answers/${questionId}?page=${page+1}&limit=${limit}`) Next
      else
        p No answers yet.
