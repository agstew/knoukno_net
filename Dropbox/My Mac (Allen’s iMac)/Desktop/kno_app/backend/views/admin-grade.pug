extends layout

block content
  h2 Grade Submission
  h3= submission.question && submission.question.text
  p Answer: #{submission.answerText}
  form(method='post' action=`/admin/grade/${submission._id}`)
    label Grade (letter)
    select(name='grade' required)
      option(value='') -- select --
      option(value='A') A
      option(value='B') B
      option(value='C') C
      option(value='D') D
      option(value='F') F
    button(type='submit') Save Grade
  a(href='/admin') Back
