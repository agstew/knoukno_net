extends layout

block content
  .container
    .dashboard-grid
      .dash-left
        .card
          .card-header
            h2 Dashboard
            .meta Small overview of your account
          .stats-grid
            .stat
              .stat-label Tier
              .stat-value #{(currentUser && currentUser.tier) ? currentUser.tier.toUpperCase() : 'FREE'}
            .stat
              .stat-label Questions Remaining
              .stat-value #{currentUser && currentUser.questionsRemaining ? currentUser.questionsRemaining : 0}
            .stat
              .stat-label Expires
              - var exp = (currentUser && currentUser.tierExpires) ? new Date(currentUser.tierExpires).toLocaleDateString() : '—'
              .stat-value #{exp}
          if currentUser && currentUser.questionsRemaining
            .progress-bar
              - var total = (currentUser.tier === 'members') ? 175 : (currentUser.tier === 'pro') ? 75 : 5
              - var used = total - (currentUser.questionsRemaining || 0)
              - var pct = Math.max(0, Math.min(100, Math.round((used/total)*100)))
              .progress-track
                .progress-fill(style=`width:${pct}%`) #{pct}% used
        .card
          .card-header
            h3 Quick Actions
            a.small(href='/questions') Manage Questions
          .quick-actions
            a.button-primary(href='/questions') Answer Next
            button.button-secondary(type='button' id='btn-print' ) Print
            a.button-secondary(href='/pricing') Upgrade
            a.button-secondary(href='/auth/logout') Logout
        .card
          .card-header
            h3 Recent Activity
            a.small(href='/dashboard/activity') View all
          ul.activity-list
            li.activity-item No recent submissions — try answering a question.

      .dash-right
        .card
          .card-header
            h3 Saved Pages
            a.small(href='/saved') View
          p.meta You can save pages to review later.
          a.button-secondary(href='/saved') Manage Saved Pages
        .card
          .card-header
            h3 Admin Tools
            span.meta Only visible to privileged users
          .admin-actions
            a.button-secondary(href='/admin') Open Admin
            form(method='post' action='/admin/save-all')
              if csrfToken
                input(type='hidden' name='_csrf' value=csrfToken)
              button.button-secondary(type='submit') Save All
            form(method='post' action='/admin/save-all')
              if csrfToken
                input(type='hidden' name='_csrf' value=csrfToken)
              button.button-danger(type='submit') Delete All

    // Recent submissions table (placeholder; links to admin when available)
    .card
      .card-header
        h3 Recent Submissions
      table.recent-table
        thead
          tr
            th When
            th Question
            th Status
            th Actions
        tbody
          tr
            td —
            td —
            td.meta No submissions yet
            td
              a.small(href='/questions') Answer one

  script(src='/dashboard.js')
