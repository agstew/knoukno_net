extends layout

block content
  h2 Answers
  if avgRating
    p Average rating: #{avgRating.toFixed(2)} / 50
  if total
    p Total answers: #{total}
  each s in submissions
    .submission.card
      p #{s.name || 'guest'} answered: #{s.answerText}
      p.meta Submitted: #{s.createdAt.toLocaleString()}
  .pager
    if page>1
      a(href=`/questions/${questionId}/answers?page=${page-1}&limit=${limit}`) Prev
    if (page*limit) < total
      a(href=`/questions/${questionId}/answers?page=${page+1}&limit=${limit}`) Next
  a(href='/questions') Back to Questions
