extends layout

block content
  .container
    h2 Average Rating
    if typeof avgRating !== 'undefined' && avgRating !== null
      p Average: #{avgRating.toFixed(2)} (from #{count} ratings)
    else
      p No ratings yet.
    a(href=`/titles/${id}`) Back to Title
