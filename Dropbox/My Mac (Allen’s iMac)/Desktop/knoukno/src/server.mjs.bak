import express from 'express';
import helmet from 'helmet';
import cors from 'cors';
import path from 'path';

import authRouter from './routes/auth.mjs';
import answersRouter from './routes/answers.routes.mjs';
import payRouter from './routes/pay.mjs';

const PORT = Number(process.env.PORT || 5001);
const app = express();

const DEFAULT_ALLOWED = [
  'http://localhost:3000', 'http://127.0.0.1:3000',
  'http://localhost:5001', 'http://127.0.0.1:5001'
];
const extra = (process.env.ALLOWED_ORIGINS || '')
  .split(',').map(s => s.trim()).filter(Boolean);
const ALLOWED = new Set([...DEFAULT_ALLOWED, ...extra]);

app.use(helmet({ contentSecurityPolicy: false }));
app.use(cors({
  origin: (o, cb) => { if (!o) return cb(null, true); cb(null, ALLOWED.has(o)); },
  credentials: true,
  methods: 'GET,HEAD,PUT,PATCH,POST,DELETE',
  allowedHeaders: 'Content-Type,Authorization'
}));
app.options('/healthz', cors());

app.use(express.json({ limit: '1mb' }));
app.use(express.static(path.join(process.cwd(), 'public')));

app.get('/healthz', (_req, res) => res.sendStatus(204));

app.use('/auth', authRouter);
app.use('/api', answersRouter);
app.use('/pay', payRouter);

app.listen(PORT, () => {
  console.log(\`API listening on http://127.0.0.1:\${PORT}\`);
});
