{
  "name": "knoukno",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "cross-env START_SERVER=1 node src/server.mjs",
    "dev": "sh ./scripts/dev.sh",
    "dev:nodemon": "cross-env START_SERVER=1 nodemon --inspect --watch src --exec node src/server.mjs",
    "build:css": "sass --no-source-map scss/style.scss public/style.css",
    "build:prisma": "prisma generate",
    "build": "npm run build:css && npm run build:prisma",
    "lint": "eslint . --ext .js,.mjs",
    "format": "prettier --write .",
    "seed": "node prisma/seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-graphql": "^0.12.0",
    "graphql": "^16.7.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^5.14.0",
    "eslint": "^8.45.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.0.0",
    "prisma": "^5.14.0",
    "sass": "^1.73.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "cross-env": "^7.0.3",
    "zod": "^3.21.4"
  },
  "engines": {
    "node": ">=18"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
